# OpenAI API Key for generating post drafts
OPENAI_API_KEY="sk-your_openai_api_key_here"

# MongoDB Connection String
MONGODB_URI="mongodb+srv://username:password@cluster.mongodb.net/?appName=SocialMediaPost"

# Gmail SMTP configuration for email notifications (Requires 16-letter App Password)
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-16-letter-app-password"

# Facebook Page configuration for Auto Post
FACEBOOK_PAGE_ID="123456789012345"
FACEBOOK_PAGE_ACCESS_TOKEN="EAALT9ZAJpkd0BRuvCqWUXqTq9Q4P3jQbwBth..."

# LinkedIn Configuration for Auto Post
LINKEDIN_ACCESS_TOKEN="your_linkedin_access_token_here"
LINKEDIN_AUTHOR_URN="urn:li:person:123456789"

# Telegram Configuration for Auto Post
TELEGRAM_BOT_TOKEN="your_telegram_bot_token_here"
TELEGRAM_CHAT_ID="@your_channel_name_or_id"
