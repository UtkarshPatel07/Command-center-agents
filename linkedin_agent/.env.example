# LinkedIn API Configuration
# Get these from the LinkedIn Developer Portal

# The OAuth 2.0 Access Token with w_member_social or w_organization_social permissions
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token_here

# The URN of the author (e.g. urn:li:person:123456789 or urn:li:organization:123456789)
LINKEDIN_AUTHOR_URN=urn:li:person:your_id_here
