# Your Discord Bot Token (from Discord Developer Portal)
DISCORD_TOKEN=your_discord_bot_token_here

# The Server (Guild) ID where you want the bot to act as a command center
CONTROL_SERVER_ID=123456789012345678

# The specific Channel ID inside the server where the bot will listen to commands
CONTROL_CHANNEL_ID=123456789012345678

# Your OpenAI API key for AI-driven responses
OPENAI_API_KEY=sk-your_openai_api_key_here

# Logging level (INFO, DEBUG, ERROR)
LOG_LEVEL=INFO
